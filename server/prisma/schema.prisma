generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String?
  createdAt DateTime      @default(now())
  posts     PostRequest[]
}

model PostRequest {
  id              String   @id @default(cuid())
  userId          String?
  prompt          String
  orgName         String?
  eventType       String?
  headline        String?
  subheadline     String?
  cta             String?
  caption         String?
  hashtags        String[]
  designStyle     String?
  canvaEditUrl    String?
  canvaDesignId   String?
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}